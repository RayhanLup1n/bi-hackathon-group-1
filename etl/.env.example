# ================================
# BI PIHPS Source
# ================================
PIHPS_BASE_URL=https://www.bi.go.id/hargapangan/WebSite
PIHPS_REQUEST_DELAY_SECONDS=2
PIHPS_MAX_RETRIES=3
PIHPS_TIMEOUT_SECONDS=30

# ================================
# BigQuery (Data Warehouse)
# Auth: gcloud auth application-default login
# ================================
GCP_PROJECT=radar-pangan-hackathon
BQ_LOCATION=asia-southeast2

# ================================
# Supabase PostgreSQL (Gold Layer)
# ================================
SUPABASE_HOST=db.xxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_password_here

# ================================
# dbt
# ================================
DBT_PROJECT_DIR=/app/project/etl/dbt_project
DBT_PROFILES_DIR=/app/project/etl/dbt_project
DBT_TARGET=prod
