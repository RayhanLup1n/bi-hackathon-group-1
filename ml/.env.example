# ── LLM Reasoning Agent (Lapis 3) ─────────────────────────────────────────────
# OpenRouter (recommended) — satu key untuk GPT-4o, Gemini, Claude, Llama, dll.
# Daftar di: https://openrouter.ai
LLM_API_KEY=sk-or-your-openrouter-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
# Alternatif jika pakai OpenAI langsung:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── Supabase / PostgreSQL ──────────────────────────────────────────────────────
SUPABASE_HOST=your-project.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DB=postgres
SUPABASE_USER=postgres.your-project-ref
SUPABASE_PASSWORD=your-password

# ── Model Paths ───────────────────────────────────────────────────────────────
ML_MODELS_DIR=ml/models
ML_HET_CSV=ml/data/het_reference.csv

# ── API Server ─────────────────────────────────────────────────────────────────
ML_API_HOST=0.0.0.0
ML_API_PORT=8001
