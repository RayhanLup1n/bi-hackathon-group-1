# ================================
# Airflow
# ================================
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here-generate-with-python
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# ================================
# BI PIHPS Source
# ================================
PIHPS_BASE_URL=https://www.bi.go.id/hargapangan/WebSite
PIHPS_REQUEST_DELAY_SECONDS=2
PIHPS_MAX_RETRIES=3
PIHPS_TIMEOUT_SECONDS=30

# ================================
# DuckDB
# ================================
DUCKDB_PATH=/opt/airflow/data/pihps.duckdb

# ================================
# dbt
# ================================
DBT_PROJECT_DIR=/opt/airflow/dbt_project
DBT_PROFILES_DIR=/opt/airflow/dbt_project
DBT_TARGET=prod
