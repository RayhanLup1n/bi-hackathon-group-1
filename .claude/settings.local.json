{
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(.envs/.env)",
      "Read(etl/.env)",
      "Read(**/*.tfvars)"
    ],
    "allow": [
      "Bash(python -c ' *)",
      "Bash(python -m pytest tests/ -v --tb=short)",
      "Bash(timeout 8 uvicorn main:app --host 0.0.0.0 --port 8000)",
      "Bash(uvicorn main:app --reload)",
      "Bash(python -m pytest tests/ -v)",
      "Bash(uvicorn main:app --port 8001)",
      "Bash(curl -s \"http://localhost:8001/api/commodity/cabai?sim_date=2026-05-01\")",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('stok:', d['stok']\\)\")",
      "Bash(curl -s \"http://localhost:8001/api/commodity/cabai?sim_date=2026-05-05\")",
      "Bash(curl -s \"http://localhost:8001/api/commodity/cabai?sim_date=2026-04-15\")",
      "Bash(curl -s 'http://localhost:8001/api/commodity/bawang?sim_date=__TRACKED_VAR__')",
      "Bash(python3 -c ' *)",
      "Bash(kill %1)",
      "Bash(curl -s \"http://localhost:8001/api/stok\")",
      "Bash(curl -s \"http://localhost:8001/api/stok?sim_date=2026-05-01\")",
      "Bash(curl -s \"http://localhost:8001/api/stok?sim_date=2026-01-15\")",
      "Bash(pkill -f \"uvicorn main:app\")",
      "Bash(curl -s \"http://localhost:8002/api/stok\")",
      "Bash(curl -s \"http://localhost:8002/api/stok?sim_date=2026-05-01\")",
      "Bash(curl -s \"http://localhost:8002/api/stok?sim_date=2026-01-15\")",
      "Bash(uvicorn main:app --port 8003)",
      "Bash(curl -s \"http://localhost:8003/api/stok?sim_date=2026-05-01\")",
      "Bash(curl -s \"http://localhost:8003/api/stok?sim_date=2026-03-10\")",
      "Bash(python3 -c \" import sys, json rows = json.load\\(sys.stdin\\) cabai = [r for r in rows if r['komoditas_key']=='cabai'] for r in cabai: print\\(r['kota_nama'], r['stok_ton'], r['pct']\\) \" kill %1)",
      "PowerShell(Get-Command uvicorn -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command python3 -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command py -ErrorAction SilentlyContinue)",
      "PowerShell(py --list 2>&1)"
    ]
  }
}
